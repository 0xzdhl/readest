# ip used by frontend/client-side urls to access the backend
HOST_IP=localhost

# ─── db (postgres) ─────────────────────────────────────────────────────────
# change to a strong password, min 32 chars
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# Connection string consumed by drizzle (apps/readest-app/src/db/client.ts).
# Use the same host/port/db as above; the role does not have to be `postgres`
# in production (see `migrations/0001_rls_and_pg_funcs.sql` for the RLS
# policies that gate `app.user_id`).
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── s3 storage through MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-secret-password
S3_BUCKET_NAME=readest-files

# ─── quotas ────────────────────────────────────────────────────────────────
# 1GB fixed quota for storage and 50k for translations
STORAGE_FIXED_QUOTA=1073741824
TRANSLATION_FIXED_QUOTA=50000
