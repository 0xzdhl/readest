# ip used by frontend/client-side urls to access the backend
HOST_IP=localhost

# ─── db (postgres) ─────────────────────────────────────────────────────────
# change to a strong password
POSTGRES_PASSWORD=readen-secret-db-pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# Connection string consumed by drizzle (apps/readest-app/src/db/client.ts).
# Use the `readest_app` role created on first boot by
# docker/volumes/db/init/00_init_roles.sql; the RLS policies in
# migrations/0001_rls_and_pg_funcs.sql gate this role on `app.user_id`.
DATABASE_URL=postgres://readest_app:readest_app@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── s3 storage through MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-secret-password
S3_BUCKET_NAME=readest-files

# ─── better-auth ───────────────────────────────────────────────────────────
# 32-byte hex (e.g. `openssl rand -hex 32`); required in production.
BETTER_AUTH_SECRET=
# Public base URL of the deployed app (also used as redirect-URI origin).
BETTER_AUTH_URL=http://localhost:3000
# Same URL exposed to the browser bundle; used by `auth/client.ts`.
VITE_BETTER_AUTH_URL=http://localhost:3000

# ─── email (Resend in prod, nodemailer/Mailpit in dev) ─────────────────────
# Leave RESEND_API_KEY blank to fall back to the SMTP transport below
# (Mailpit by default — see compose.yaml). Browse delivered messages at
# http://localhost:8025 when running the dev stack.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@readest.app
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── OAuth providers ───────────────────────────────────────────────────────
# Leave blank to disable a provider. Redirect URIs (configure in each
# provider's console):
#   web:    ${BETTER_AUTH_URL}/api/auth/callback/<provider>
#   tauri:  http://localhost:<port>/  (port assigned at runtime)
#   mobile: readest://auth-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── quotas ────────────────────────────────────────────────────────────────
# 1GB fixed quota for storage and 50k for translations
STORAGE_FIXED_QUOTA=1073741824
TRANSLATION_FIXED_QUOTA=50000
