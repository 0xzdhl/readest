VITE_APP_PLATFORM=web

VITE_POSTHOG_KEY=YOUR_POSTHOG_KEY
VITE_POSTHOG_HOST=YOUR_POSTHOG_HOST

# ─── better-auth ───────────────────────────────────────────────────────────
# 32-byte hex (e.g. `openssl rand -hex 32`)
BETTER_AUTH_SECRET=replace-me-with-32-byte-hex
# Public base URL of the deployed app (also used as redirect-URI origin).
BETTER_AUTH_URL=http://localhost:3000
# Same URL exposed to the browser bundle; used by `auth/client.ts`.
VITE_BETTER_AUTH_URL=http://localhost:3000

# ─── database ──────────────────────────────────────────────────────────────
# postgres://<role>:<password>@<host>:<port>/<db>
# The app connects as the constrained `readest_app` role so RLS policies
# apply. The role is bootstrapped by docker/volumes/db/init/00_init_roles.sql
# (also idempotent in migration 0001).
DATABASE_URL=postgres://readest_app:readest_app@localhost:5432/postgres
# For running `pnpm db:migrate` you need to connect as a superuser since the
# migration script issues CREATE ROLE / CREATE EXTENSION / GRANT statements.
# In the docker compose stack the default postgres user is `postgres` with
# the password from POSTGRES_PASSWORD in docker/.env.
# Example (one-shot): DATABASE_URL=postgres://postgres:<pw>@localhost:5432/postgres pnpm db:migrate
# Optional: max pool size used by `db/client.ts` (default 10)
# DATABASE_POOL_MAX=10

# ─── email (Resend in prod, nodemailer/Mailpit in dev) ─────────────────────
# Production: set RESEND_API_KEY to enable the Resend SDK path.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@readest.app
# Development fallback (used when RESEND_API_KEY is empty).
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── OAuth providers ───────────────────────────────────────────────────────
# Redirect URIs (configure in each provider's console):
#   web:    ${BETTER_AUTH_URL}/api/auth/callback/<provider>
#   tauri:  http://localhost:<port>/  (port assigned at runtime)
#   mobile: readest://auth-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

AI_GATEWAY_API_KEY=your_key_here
