# Copy this file to .env for local development.
# The web build, Drizzle Kit, Wrangler, and the Cloudflare Vite plugin all read .env.
# npm scripts set VITE_APP_PLATFORM for each target; do not set it here.

# ─── app assets ───────────────────────────────────────────────────────────
PDFJS_BUILD_PATH=../../packages/foliate-js/node_modules/pdfjs-dist/legacy/build
PDFJS_FONTS_PATH=../../packages/foliate-js/node_modules/pdfjs-dist
PDFJS_STYLE_PATH=../../packages/foliate-js/vendor/pdfjs

# ─── public client env ────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5173
VITE_NODE_BASE_URL=http://localhost:5173
VITE_BETTER_AUTH_URL=http://localhost:5173
VITE_STORAGE_FIXED_QUOTA=1073741824
VITE_TRANSLATION_FIXED_QUOTA=50000
VITE_OBJECT_STORAGE_TYPE=s3

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
VITE_DEFAULT_POSTHOG_URL_BASE64=PUT_YOUR_URL_HERE
VITE_DEFAULT_POSTHOG_KEY_BASE64=PUT_YOUR_KEY_HERE

VITE_STRIPE_PUBLISHABLE_KEY_DEV_BASE64=PUT_YOUR_KEY_HERE
VITE_STRIPE_PUBLISHABLE_KEY_BASE64=PUT_YOUR_KEY_HERE
VITE_USE_APPLE_SIGN_IN=false

# ─── database / auth ──────────────────────────────────────────────────────
# For local docker, use the postgres password from docker/.env.
# Drizzle migrations need a superuser because they create roles and grants.
DATABASE_URL=postgres://postgres:readest-dev@localhost:5432/postgres

# Use `openssl rand -base64 32` to generate.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# ─── email ────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@readest.app
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── OAuth providers ──────────────────────────────────────────────────────
# Redirect URIs:
#   web:    ${BETTER_AUTH_URL}/api/auth/callback/<provider>
#   tauri:  http://localhost:<port>/  (port assigned at runtime)
#   mobile: readest://auth-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── AI / translation ─────────────────────────────────────────────────────
AI_GATEWAY_API_KEY=
AI_GATEWAY_EMBEDDING_MODEL=openai/text-embedding-3-small
DEEPL_PRO_API_KEYS=
DEEPL_FREE_API_KEYS=
DEEPL_PRO_API=https://api.deepl.com/v2/translate
DEEPL_FREE_API=https://api-free.deepl.com/v2/translate
DEEPL_X_FINGERPRINT=

# ─── object storage ───────────────────────────────────────────────────────
# VITE_OBJECT_STORAGE_TYPE chooses r2 or s3.
R2_TOKEN_VALUE=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_REGION=auto

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin-secret-password
S3_BUCKET_NAME=readest-files
S3_REGION=us-east-1

TEMP_STORAGE_PUBLIC_BUCKET_NAME=

# ─── payments ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_DEV=
STRIPE_WEBHOOK_SECRET=

# ─── Tauri optional overrides ─────────────────────────────────────────────
TAURI_DEV_HOST=
VITE_DIST_CHANNEL=readest
VITE_DISABLE_UPDATER=false
VITE_PORTABLE_APP=false
